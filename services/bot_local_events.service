[Unit]
Description=GunLinuxBot Local Events Service
After=network.target

[Service]
ExecStart=uv run /home/loki/projects/gunlinuxbot_new/local_events/local.py
WorkingDirectory=/home/loki/projects/gunlinuxbot_new/local_events/
Environment=REDIS_URL=redis://gunlinux.ru/2
Restart=always
RestartSec=10

[Install]
WantedBy=default.target
